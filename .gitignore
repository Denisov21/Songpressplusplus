/build/*/
/dist/

# Cache Python
__pycache__/
*.pyc
*.pyo

# File di log
*.log

# NSIS output (se compili dall'interno del progetto)
/installer/*.exe

# File temporanei Office / Windows
~$*
Thumbs.db
Desktop.ini
