# -----------------------------------------------------------------------
# SyntaxCheckerDialog.py
# -----------------------------------------------------------------------

#. Window title
#: SyntaxCheckerDialog.py:27
msgid "Syntax check"
msgstr "Verifica sintattica"

#. Success message when no errors are found
#: SyntaxCheckerDialog.py:81
msgid "No syntax errors found."
msgstr "Nessun errore sintattico trovato."

#. Button: navigate to the selected error
#: SyntaxCheckerDialog.py:56
msgid "Go to error"
msgstr "Vai all'errore"

#. Button: close the dialog
#: SyntaxCheckerDialog.py:61
msgid "Close"
msgstr "Chiudi"

#. Error list header — singular
#: SyntaxCheckerDialog.py:96
msgid "Found 1 syntax error:"
msgstr "Trovato 1 errore sintattico:"

#. Error list header — plural
#: SyntaxCheckerDialog.py:98
msgid "Found {count} syntax errors:"
msgstr "Trovati {count} errori sintattici:"

#. Column header: line number
#: SyntaxCheckerDialog.py:111
msgid "Line"
msgstr "Riga"

#. Column header: column number
#: SyntaxCheckerDialog.py:112
msgid "Column"
msgstr "Colonna"

#. Column header: error description
#: SyntaxCheckerDialog.py:113
msgid "Description"
msgstr "Descrizione"

# -----------------------------------------------------------------------
# SyntaxChecker.py — error messages
# -----------------------------------------------------------------------

#. Square bracket opened but never closed
#: SyntaxChecker.py
msgid "Opening square bracket '[' not closed"
msgstr "Parentesi quadra aperta '[' non chiusa"

#. Chord brackets with no content inside
#: SyntaxChecker.py
msgid "Empty chord '[]'"
msgstr "Accordo vuoto '[]'"

#. Closing square bracket with no matching opening bracket
#: SyntaxChecker.py
msgid "Closing square bracket ']' without opening"
msgstr "Parentesi quadra chiusa ']' senza apertura"

#. Curly brace opened but never closed
#: SyntaxChecker.py
msgid "Opening curly brace '{' not closed"
msgstr "Parentesi graffa aperta '{' non chiusa"

#. Closing curly brace with no matching opening brace
#: SyntaxChecker.py
msgid "Closing curly brace '}' without opening"
msgstr "Parentesi graffa chiusa '}' senza apertura"

#. Curly braces with no command name inside
#: SyntaxChecker.py
msgid "Empty command '{}'"
msgstr "Comando vuoto '{}'"

#. Command name not in the list of known ChordPro commands
#. {cmd} is replaced at runtime with the actual command, e.g. {stat_chorus}
#: SyntaxChecker.py
msgid "Unknown command: '{cmd}'"
msgstr "Comando sconosciuto: '{cmd}'"

#. Known command used without a required value (e.g. {title:} with no text)
#. {cmd} is replaced at runtime with the actual command+colon, e.g. {title:}
#: SyntaxChecker.py
msgid "Command '{cmd}' requires a value"
msgstr "Il comando '{cmd}' richiede un valore"

#. Optional-value command written with ':' but no value (e.g. {textsize:} instead of {textsize})
#. {cmd} is replaced with the erroneous form, {reset} with the correct reset form
#: SyntaxChecker.py
msgid "Command '{cmd}' has ':' but no value; use '{reset}' to reset"
msgstr "Il comando '{cmd}' ha ':' ma nessun valore; usa '{reset}' per ripristinare il default"
