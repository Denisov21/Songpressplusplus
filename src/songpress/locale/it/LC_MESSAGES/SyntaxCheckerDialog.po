#. Titolo della finestra di dialogo
#: SyntaxCheckerDialog.py:26
msgid "Syntax check"
msgstr "Verifica sintattica"

#. Messaggio mostrato quando non ci sono errori
#: SyntaxCheckerDialog.py:72
msgid "No syntax errors found."
msgstr "Nessun errore sintattico trovato."

#. Testo del pulsante per navigare all'errore selezionato
#: SyntaxCheckerDialog.py:50
msgid "Go to error"
msgstr "Vai all'errore"

#. Testo del pulsante di chiusura
#: SyntaxCheckerDialog.py:55
msgid "Close"
msgstr "Chiudi"

#. Intestazione lista errori — forma singolare
#: SyntaxCheckerDialog.py:86
msgid "Found 1 syntax error:"
msgstr "Trovato 1 errore sintattico:"

#. Intestazione lista errori — forma plurale
#: SyntaxCheckerDialog.py:86
msgid "Found {count} syntax errors:"
msgstr "Trovati {count} errori sintattici:"

#. Etichetta colonna "Riga" nella lista errori
#: SyntaxCheckerDialog.py:93
msgid "Line"
msgstr "Riga"

#. Etichetta colonna "Colonna" nella lista errori
#: SyntaxCheckerDialog.py:94
msgid "Column"
msgstr "Colonna"

#. Etichetta colonna "Descrizione" nella lista errori
#: SyntaxCheckerDialog.py:95
msgid "Description"
msgstr "Descrizione"
