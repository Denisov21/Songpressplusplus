#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:54
msgid "Replace"
msgstr "Sostituisci"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:54
msgid "Find"
msgstr "Trova"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:98
msgid "beginning"
msgstr "l'inizio"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:99
msgid "Reached the end"
msgstr "Raggiunta la fine"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:102
msgid "end"
msgstr "la fine"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:103
msgid "Reached the beginning"
msgstr "Raggiunto l'inizio"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:107
#, python-format
msgid "%s of the song, restarting search from the %s"
msgstr "%s della canzone; la ricerca riprende dal%s"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:118
msgid "The specified text was not found"
msgstr "Il testo immesso non è stato trovato"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:156
#, python-format
msgid "%d text occurrences have been replaced"
msgstr "Sono state sostituite %d occorrenze del testo"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:171
#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:181
msgid "All supported files"
msgstr "Tutti i file supportati"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:182
msgid "Chordpro files (*.crd, *.cho, *.chordpro, *.chopro, *.pro)"
msgstr "File ChordPro (*.crd, *.cho, *.chordpro, *.chopro, *.pro)"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:183
msgid "Tab files (*.tab)"
msgstr "File in formato tab (*.tab)"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:195
msgid "song"
msgstr "canzone"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
msgid ""
"An error occurred while printing.\n"
"Please check your printer settings."
msgstr ""
"Si è verificato un errore durante la stampa.\n"
"Controllare le impostazioni della stampante."

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
msgid "Display as:"
msgstr "Visualizza come:"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
msgid "Enter a label for the chorus, or press Cancel to omit the label."
msgstr "Inserisci un'etichetta per il ritornello, o premi Annulla per ometterla."

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
msgid "File guida.md not found in the program folder."
msgstr "File guida.md non trovato nella cartella del programma."

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
msgid "Help"
msgstr "Guida"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
msgid "Time:"
msgstr "Tempo:"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
msgid "PDF"
msgstr "PDF"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
msgid "Quick guide - Songpress++++"
msgstr "Guida rapida - Songpress++++"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
msgid ""
"Unable to create print preview.\n"
"Please check your printer settings."
msgstr ""
"Impossibile creare l'anteprima di stampa.\n"
"Controllare le impostazioni della stampante."

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:200
msgid "Original version website: http://www.skeed.it/songpress"
msgstr "Sito web versione originale: http://www.skeed.it/songpress"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:201
