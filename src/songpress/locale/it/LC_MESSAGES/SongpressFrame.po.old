#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
msgid "Time"
msgstr "Tempo"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
msgid "Enter the song tempo (e.g. 120):"
msgstr "Inserisci il tempo della canzone (es. 120):"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
msgid "Chord keys"
msgstr "Tasti accordo"

