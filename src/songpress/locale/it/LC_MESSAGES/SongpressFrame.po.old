"  * python-pptx (for PowerPoint export)"
msgstr ""
"Un sentito ringraziamento a:\n"
"  * Il linguaggio di programmazione Pyhton (http://www.python.org)\n"
"  * wxWidgets (http://www.wxwidgets.org)\n"
"  * wxPython (http://www.wxpython.org)\n"
"  * Editra (http://editra.org/) (per la finestra di segnalazione errori e... per l'editor in quanto tale!)\n"
"  * python-pptx (per l'esportazione in PowerPoint)"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:224
msgid "New"
msgstr "Nuovo"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:224
msgid "Create a new song"
msgstr "Crea una nuova canzone"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:225
msgid "Open"
msgstr "Apri"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:225
msgid "Open an existing song"
msgstr "Apre una canzone esistente"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:226
msgid "Save"
msgstr "Salva"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:226
msgid "Save the song with the current file name"
msgstr "Salva la canzone con il nome del file attuale"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:228
msgid "Undo"
msgstr "Annulla"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:228
msgid "Undo the last change"
msgstr "Annulla l'ultima modifica"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:230
msgid "Redo"
msgstr "Ripeti"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:230
msgid "Redo the last undone change"
msgstr "Ripete la modifica precedentemente annullata"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:233
msgid "Cut"
msgstr "Taglia"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:234
msgid "Move selected text to the clipboard"
msgstr "Sposta il testo selezionato negli appunti"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:235
msgid "Copy"
msgstr "Copia"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:236
msgid "Copy selected text to the clipboard"
msgstr "Copia il testo selezionato negli appunti"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:238
msgid "Copy as image"
msgstr "Copia come immagine"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:239
msgid "Copy the entire FORMATTED song (or selected verses) to the clipboard"
msgstr "Copia la canzone FORMATTATA (tutta o le strofe selezionate) negli appunti"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:240
msgid "Paste"
msgstr "Incolla"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:241
msgid "Read text from the clipboard and insert it at the cursor position"
msgstr "Legge il testo dagli appunti e lo inserisce nella posizione del cursore"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:242
msgid "Paste chords"
msgstr "Incolla Accordi"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:243
msgid "Merge chords from the copied text into the current selection"
msgstr "Unisce gli accordi del testo copiato nella selezione corrente"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:258
msgid "Insert title"
msgstr "Inserisci titolo"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:259
msgid "Insert a command to display the song title"
msgstr "Inserisce un comando che mostra il titolo della canzone"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:260
msgid "Insert chord"
msgstr "Inserisci accordo"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:261
msgid "Insert square brackets that will contain a chord"
msgstr "Inserisce delle parentesi quadre, che conterranno un accordo"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:262
msgid "Insert chorus"
msgstr "Inserisci ritornello"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:263
msgid "Insert a pair of commands that will contain the chorus"
msgstr "Inserisce due comandi, tra i quali scrivere il ritornello"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:268
msgid "Insert verse with custom label or without label"
msgstr "Inserisci una strofa con un'etichetta personalizzata o senza etichetta"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:269
msgid "Insert a verse with a custom label or without label"
msgstr "Inserisce un comando per mostrare una strofa con un'etichetta personalizzabile"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:277
msgid "Show verse labels"
msgstr "Mostra le etichette delle strofe"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:278
msgid "Show or hide verse and chorus labels"
msgstr "Mostra o nasconde le etichette delle strofe e dei ritornelli"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:285
#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:286
msgid "Hide or show chords in the formatted song"
msgstr "Mostra o nasconde gli accordi nella canzone formattata"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:325
msgid ""
"You are not a skilled guitarist? Songpress++ can help you: when you open a song, it can detect if chords are difficult. If this is the case, Songpress++ will alert you, and offer to transpose your song to the easiest key, automatically.\n"
"\n"
"Do you want to turn this option on?"
msgstr ""
"Non sei un chitarrista esperto? Songpress++ ti può aiutare: quando apri una canzone, può determinare se gli accordi sono difficili. In tal caso Songpress++ ti avvertirà e si offrirà di trasporre la canzone nella tonalità più facile, automaticamente.\n"
"\n"
"Vuoi attivare questa funzionalità?"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:326
#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:331
#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:839
#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:997
msgid "Songpress++"
msgstr "Songpress++"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:330
msgid "Please take a minute to set up your skill as a guitarist. For each group of chords, tell Songpress++ how much you like them."
msgstr "Ora dedica un minuto ad impostare il tuo livello di abilità come chitarrista. Esprimi il tuo grado di preferenza per ciascuno dei gruppi di accordi che ti verranno presentati."

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:548
msgid "PNG image"
msgstr "Immagine PNG"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:555
msgid "HTML file"
msgstr "File HTML"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:568
msgid "TAB file"
msgstr "File TAB"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:588
msgid "SVG image"
msgstr "Immagine SVG"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:593
msgid "Enhanced Metafile"
msgstr "Metafile avanzato"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:600
msgid "EPS image"
msgstr "Immagine EPS"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:607
msgid "Exporting image as EPS..."
msgstr "Esportazione in formato EPS..."

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:615
msgid "Please install the python-pptx module to use this feature"
msgstr "Installa il modulo python-pptx per usare questa funzionalità"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:627
msgid "Please select a template for your PowerPoint presentation:"
msgstr "Scegli un template per la presentazione PowerPoint:"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:628
msgid "Export as PowerPoint"
msgstr "Esporta come PowerPoint"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:632
msgid "PPTX presentation"
msgstr "Presentazione PPTX"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:817
msgid "http://www.skeed.it/songpress-manual"
msgstr "http://www.skeed.it/songpress-manuale"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:836
msgid "http://www.skeed.it/songpress#donate"
msgstr "http://www.skeed.it/songpress-it#donate"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:887
#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:1049
msgid "Simplify chords"
msgstr "Semplifica gli accordi"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:889
#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:1047
#, python-format
msgid "The key of your song, %s, is not the easiest to play (difficulty: %.1f/5.0).\n"
msgstr "La canzone è in %s. Questa non è la tonalità più facile da suonare (difficoltà %.1f/5.0).\n"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:890
#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:1048
#, python-format
msgid "Do you want to transpose the key %s, which is the easiest one (difficulty: %.1f/5.0)?"
msgstr "Vuoi trasporla in %s, che è la tonalità più semplice (difficoltà: %.1f/5.0)?"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:897
#, python-format
msgid "The key of your song, %s, is already the easiest to play (difficulty: %.1f/5.0).\n"
msgstr "La canzone è già nella tonalità più facile da suonare, il %s (difficoltà %.1f/5.0).\n"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:899
msgid "Your song or current selection does not contain any chords."
msgstr "La canzone o la selezione corrente non contiene accordi."

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:967
msgid "Insert a label for verse, or press Cancel if you want to omit label."
msgstr "Inserisci un'etichetta per la strofa, o premi Annulla per omettere l'etichetta."

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:968
msgid "Verse label"
msgstr "Etichetta della strofa"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:977
msgid "Insert a label for chorus, or press Cancel if you want to omit label."
msgstr "Inserisci un'etichetta per il ritornello, o premi Annulla per omettere l'etichetta."

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:978
msgid "Chorus label"
msgstr "Etichetta del ritornello"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:996
msgid "Please enter a label for chorus"
msgstr "Etichetta per il ritornello"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:1023
msgid "It looks like there are spurious blank lines in the song.\n"
msgstr "A quanto pare la canzone contiene troppe linee vuote.\n"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:1024
msgid "Do you want to try to remove them automatically?"
msgstr "Vuoi provare a rimuoverle automaticamente?"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:1025
msgid "Remove spurious blank lines"
msgstr "Rimuovi le linee vuote di troppo"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:1035
msgid "It looks like your song is in tab format (i.e., chords are above the text).\n"
msgstr "A quanto pare la canzone è nel formato tab (cioè gli accordi si trovano sopra il testo).\n"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:1036
msgid "Do you want to convert it to ChordPro automatically?"
msgstr "Vuoi convertirla automaticamente al formato ChordPro?"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:1037
msgid "Convert to ChordPro"
msgstr "Converti a ChordPro"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
msgid "Song"
msgstr "Canzone"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
msgid "Print preview error"
msgstr "Errore nell'anteprima di stampa"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
msgid "Print..."
msgstr "Stampa..."

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
msgid "Next page"
msgstr "Pagina successiva"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
msgid "Previous page"
msgstr "Pagina precedente"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
msgid "First page"
msgstr "Prima pagina"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
msgid "Last page"
msgstr "Ultima pagina"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
msgid "Close"
msgstr "Chiudi"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
msgid "Page setup..."
msgstr "Imposta pagina..."

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
msgid "Line spacing"
msgstr "Interlinea"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
msgid "Enter the line spacing value (e.g. 0 to remove extra space):"
msgstr "Inserisci il valore dell'interlinea (es. 0 per rimuovere lo spazio extra):"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
msgid "Space above chords"
msgstr "Spazio sopra accordi"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
msgid "Enter the space above chords value (e.g. 0 to remove extra space):"
msgstr "Inserisci il valore dello spazio sopra gli accordi (es. 0 per rimuovere lo spazio extra):"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
msgid "Intro"
msgstr "Intro"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
#, python-format
msgid "Enter a label for the intro chords, or press Cancel to use '%s'."
msgstr "Inserisci un'etichetta per gli accordi di introduzione, o premi Annulla per usare '%s'."

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
msgid "Intro chords label"
msgstr "Etichetta accordi introduzione"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
msgid "Bridge"
msgstr "Bridge"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
#, python-format
msgid "Enter a label for the bridge, or press Cancel to use '%s'."
msgstr "Inserisci un'etichetta per l'inciso, o premi Annulla per usare '%s'."

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
msgid "Bridge label"
msgstr "Etichetta inciso"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:1240
msgid "Command 'Paste chords': Select 1st chord line, 2nd text line"
msgstr "Comando 'Integra accordi': Seleziona 1° linea accordi,  2° linea testo"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
msgid "Print options..."
msgstr "Opzioni di stampa..."

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py
msgid "Print"
msgstr "Stampa"

