"\n"
"This is a folk version by Denisov21"
msgstr ""
"Copyright (c) 2009-{year} Luca Allulli - Skeed\n"
"Localizzazione:\n"
"{translations}\n"
"\n"
"Questa è una versione folk di Denisov21"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:205
msgid "Licensed under the terms and conditions of the GNU General Public License, version 2"
msgstr "Concesso in licenza secondo i termini e le condizioni della GNU General Public License, versione 2"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/SongpressFrame.py:207
