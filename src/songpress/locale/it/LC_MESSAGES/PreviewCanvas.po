#: PreviewCanvas.py:100
msgid "Copy formatted song to clipboard"
msgstr "Copia la canzone formattata negli appunti"

#: PreviewCanvas.py:112
msgid "Zoom out (Ctrl+-)"
msgstr "Riduci zoom (Ctrl+-)"

#: PreviewCanvas.py:126
msgid "Zoom in (Ctrl++)"
msgstr "Aumenta zoom (Ctrl++)"


#: PreviewCanvas.py
msgid "Zoom level — drag or use Ctrl+Scroll"
msgstr "Livello zoom — trascina o usa Ctrl+Rotella"

#: PreviewCanvas.py:132
msgid "Reset zoom to 100% (Ctrl+0)"
msgstr "Ripristina zoom al 100% (Ctrl+0)"

#: PreviewCanvas.py:139
msgid "Fit"
msgstr "Adatta"

#: PreviewCanvas.py:141
msgid "Fit preview width to panel (Ctrl+Shift+G)"
msgstr "Adatta la larghezza dell'anteprima al pannello (Ctrl+Shift+G)"

#: PreviewCanvas.py:334
msgid "Page %d of %d"
msgstr "Pagina %d di %d"

#: SongpressFrame.py PreferencesDialog.py
msgid "Songpress++ Preview"
msgstr "Anteprima Songpress++"

#: PreviewCanvas.py
msgid "Full screen preview (F11)"
msgstr "Anteprima a tutto schermo (F11)"

#: PreviewCanvas.py
msgid "Preview — press Esc or F11 to exit full screen"
msgstr "Anteprima — premi Esc o F11 per uscire dal tutto schermo"

#: PreviewCanvas.py
msgid "Exit full screen (Esc / F11)"
msgstr "Esci dal tutto schermo (Esc / F11)"
