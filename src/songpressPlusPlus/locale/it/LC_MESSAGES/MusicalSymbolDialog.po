# --- Dialog title & buttons ---

#: MusicalSymbolDialog.py
msgid "Musical Symbols"
msgstr "Simboli musicali"

#: MusicalSymbolDialog.py
msgid "Insert"
msgstr "Inserisci"

#: MusicalSymbolDialog.py
msgid "Close"
msgstr "Chiudi"

#. Checkbox label for custom font size when inserting a musical symbol
#: MusicalSymbolDialog.py:620
msgid "Custom size (pt):"
msgstr "Dimensione personalizzata (pt):"

#. Info note shown below the size controls
#: MusicalSymbolDialog.py
msgid "Note: not all symbols can be resized!"
msgstr "Nota: non tutti i simboli si possono dimensionare!"

#. Checkbox label: wrap the symbol in a non-counted verse block
#: MusicalSymbolDialog.py
msgid "Wrap symbol in a verse block (not counted)"
msgstr "Incorpora il simbolo in una strofa (non conteggiata)"

#. Tooltip for the wrap-in-verse checkbox (multiline)
#: MusicalSymbolDialog.py
msgid ""
"When enabled, the symbol is wrapped inside {start_verse}...{end_verse}\n"
"so it appears as a verse block without being counted in the verse numbering.\n"
"Example: {start_verse}{textsize:24}♩{textsize}{end_verse}"
msgstr ""
"Se attiva, il simbolo viene incluso in {start_verse}...{end_verse}\n"
"e appare come blocco strofa senza essere conteggiato nella numerazione.\n"
"Esempio: {start_verse}{textsize:24}♩{textsize}{end_verse}"

