# ── Dialog title ──────────────────────────────────────────────────────────────

msgid "Print options"
msgstr "Opzioni di stampa"

# ── Section headers ───────────────────────────────────────────────────────────

msgid "Pages"
msgstr "Pagine"

msgid "Columns per page"
msgstr "Colonne per pagina"

msgid "Scaling"
msgstr "Ridimensionamento"

msgid "Advanced options"
msgstr "Opzioni avanzate"

msgid "Scale"
msgstr "Scala"

# ── Checkboxes and labels ─────────────────────────────────────────────────────

msgid "Print 2 pages per sheet"
msgstr "Stampa 2 pagine per foglio"

msgid "1 column"
msgstr "1 colonna"

msgid "2 columns"
msgstr "2 colonne"

msgid "Fit to page"
msgstr "Riduci e adatta alla pagina"

msgid "Shrink to fit current page"
msgstr "Riduci per adattare alla pagina corrente"

msgid "(prevent bottom clipping)"
msgstr "(evita il taglio in fondo)"

msgid "Min margin for auto-shrink (mm):"
msgstr "Margine minimo per riduzione automatica (mm):"

msgid "Do not replicate (leave right half blank)"
msgstr "Non replicare (lascia bianca la metà destra)"

msgid "Remove blank pages"
msgstr "Rimuovi pagine bianche"

msgid "Blank page threshold (%):"
msgstr "Soglia pagina vuota (%):"

msgid "Scale (%):"
msgstr "Scala (%):"

# ── Buttons and tooltips ──────────────────────────────────────────────────────

msgid "Keep this dialog open after applying"
msgstr "Mantieni aperto il dialog dopo aver applicato"

msgid "OK"
msgstr "OK"

msgid "Cancel"
msgstr "Annulla"

# ── PrintManager / preview toolbar ───────────────────────────────────────────

msgid "Print"
msgstr "Stampa"

msgid "Print..."
msgstr "Stampa..."

msgid "Print options..."
msgstr "Opzioni di stampa..."

msgid "Page setup..."
msgstr "Impostazione pagina..."

msgid "Print preview"
msgstr "Anteprima di stampa"

msgid "Print preview error"
msgstr "Errore anteprima di stampa"

msgid "Unable to create print preview.\nPlease check your printer settings."
msgstr "Impossibile creare l'anteprima di stampa.\nControllare le impostazioni della stampante."

msgid "Print error"
msgstr "Errore di stampa"

msgid "An error occurred while printing.\nPlease check your printer settings."
msgstr "Si è verificato un errore durante la stampa.\nControllare le impostazioni della stampante."

msgid "Next page"
msgstr "Pagina successiva"

msgid "Previous page"
msgstr "Pagina precedente"

msgid "First page"
msgstr "Prima pagina"

msgid "Last page"
msgstr "Ultima pagina"

msgid "Close"
msgstr "Chiudi"

msgid "Selection"
msgstr "Selezione"
