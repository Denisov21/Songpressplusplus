# CanzonatorDialog.py
# ════════════════════════════════════════════════════════════════════════════

# ── Titoli dialogo ──────────────────────────────────────────────────────────
msgid "Canzonatore — Merge songs"
msgstr "Canzonatore — Unisci brani"

msgid "Canzonatore — Merge completed"
msgstr "Canzonatore — Unione completata"

# ── Titolo app (usato nei MessageBox) ──────────────────────────────────────
msgid "Canzonatore"
msgstr "Canzonatore"

# ── Etichette finestra principale ───────────────────────────────────────────
msgid "Files to merge (order = order in output) — double-click to open:"
msgstr "File da unire (ordine = ordine nel file finale) — doppio clic per aprire:"

# ── Colonne lista ───────────────────────────────────────────────────────────
msgid "File"
msgstr "File"

msgid "Folder"
msgstr "Cartella"

# ── Pulsanti gestione lista ─────────────────────────────────────────────────
msgid "Add files…"
msgstr "Aggiungi file…"

msgid "Add folder…"
msgstr "Aggiungi cartella…"

msgid "Remove"
msgstr "Rimuovi"

msgid "▲ Up"
msgstr "▲ Su"

msgid "▼ Down"
msgstr "▼ Giù"

msgid "Clear all"
msgstr "Cancella tutto"

# ── Gruppo opzioni ──────────────────────────────────────────────────────────
msgid "Options"
msgstr "Opzioni"

msgid "Song separator:"
msgstr "Separatore brani:"

msgid "{new_page}  (page break)"
msgstr "{new_page}  (interruzione pagina)"

msgid "Blank line"
msgstr "Riga vuota"

msgid "Output encoding:"
msgstr "Codifica output:"

msgid "Open the merged file in the editor"
msgstr "Apri il file unito nell'editor"

# ── Pulsanti principali ─────────────────────────────────────────────────────
msgid "Merge…"
msgstr "Unisci…"

msgid "Close"
msgstr "Chiudi"

msgid "OK"
msgstr "OK"

# ── Filtri file ─────────────────────────────────────────────────────────────
msgid "All supported files"
msgstr "Tutti i file supportati"

msgid "All files"
msgstr "Tutti i file"

msgid "ChordPro files"
msgstr "File ChordPro"

msgid "Select files to add"
msgstr "Seleziona file da aggiungere"

msgid "Select folder"
msgstr "Seleziona cartella"

msgid "Save merged file as…"
msgstr "Salva file unito come…"

# ── Dialogo completamento merge ─────────────────────────────────────────────
#. %d = numero brani uniti
msgid "Merge completed: %d songs merged."
msgstr "Unione completata: %d brani uniti."

#. %d = numero file saltati per errore
msgid "(%d file(s) skipped due to read errors)"
msgstr "(%d file saltati per errori di lettura)"

msgid "Output file:"
msgstr "File di output:"

msgid "Open the file with the default application"
msgstr "Apri il file con l'applicazione predefinita"

msgid "Open the containing folder"
msgstr "Apri la cartella contenente il file"

# ── Messaggi di errore / avviso ─────────────────────────────────────────────
msgid "Add at least one file to merge."
msgstr "Aggiungere almeno un file da unire."

msgid "Remove all files from the list?"
msgstr "Rimuovere tutti i file dall'elenco?"

#. %d = numero file saltati
msgid "%d file(s) skipped (unsupported format or already in list)."
msgstr "%d file saltati (formato non supportato o già presenti nell'elenco)."

msgid "No supported files found in the selected folder."
msgstr "Nessun file supportato trovato nella cartella selezionata."

msgid "Errors reading the following files:\n\n"
msgstr "Errori nella lettura dei seguenti file:\n\n"

msgid "Error writing the merged file:\n\n"
msgstr "Errore nella scrittura del file unito:\n\n"
