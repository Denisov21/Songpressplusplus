#: PreferencesDialog.py — General tab, single instance checkbox
msgid "Single instance: open files in the existing window"
msgstr "Istanza singola: apri i file nella finestra esistente"

#: PreferencesDialog.py — General tab, single instance checkbox tooltip
msgid "When enabled, opening a file from Explorer or the command line will reuse the existing Songpress++ window instead of launching a new instance."
msgstr "Se attivo, aprire un file da Explorer o dalla riga di comando riutilizza la finestra di Songpress++ già aperta, invece di avviarne una nuova."

# — Preferenze — gruppo Stampa (tab Songpress++ Preview)
msgid "Print"
msgstr "Stampa"

#: PreferencesDialog.py — Print group, live update checkbox
msgid "Live update of duplex/color status in print preview (every 1.5 s)"
msgstr "Aggiornamento in tempo reale dello stato fronte/retro e colore nell'anteprima (ogni 1,5 s)"

#: PreferencesDialog.py — Print group, live update checkbox tooltip
msgid "When enabled, the duplex and color status shown in the print preview status bar is refreshed every 1.5 seconds by querying the printer driver. This lets you see changes made in the driver panel without closing the preview. When disabled, the status is read once when the preview opens and stays fixed."
msgstr ""
"Se attivo, lo stato fronte/retro e colore mostrato nella barra di stato\n"
"dell'anteprima di stampa viene aggiornato ogni 1,5 secondi interrogando\n"
"il driver della stampante. Ciò consente di vedere le modifiche apportate\n"
"nel pannello del driver senza chiudere l'anteprima. Se disattivo, lo stato\n"
"viene letto una sola volta all'apertura dell'anteprima e rimane fisso."

#: PreferencesDialog.py — Print group, always on top checkbox
msgid "Keep print preview window always on top"
msgstr "Mantieni sempre in primo piano la finestra di anteprima di stampa"

#: PreferencesDialog.py — Print group, always on top checkbox tooltip
msgid "When enabled, the print preview window stays on top of all other windows, including the main Songpress++ window. When disabled, the preview window behaves as a normal window."
msgstr ""
"Se attivo, la finestra di anteprima di stampa rimane sempre in primo piano\n"
"rispetto a tutte le altre finestre, inclusa la finestra principale di Songpress++.\n"
"Se disattivo, la finestra di anteprima si comporta come una finestra normale."

#: PreferencesDialog.py — Context menu tab, Appearance group label
msgid "Appearance"
msgstr "Aspetto"

#: PreferencesDialog.py — Context menu tab, Appearance group, show icons checkbox
msgid "Show icons in context menu"
msgstr "Mostra icone nel menu contestuale"
