msgid "Enable directive intellisense (Ctrl+Space)"
msgstr "Abilita intellisense direttive (Ctrl+Spazio)"

#: PreferencesDialog.py format tab — beat count group title
msgid "Beat count ({beats_time})"
msgstr "Numero di battiti ({beats_time})"

#: PreferencesDialog.py format tab — beat count colour label
msgid "Colour"
msgstr "Colore"

#: PreferencesDialog.py format tab — beat count font size label
msgid "Font size (% of chord font)"
msgstr "Dimensione carattere (% del carattere accordo)"

#: PreferencesDialog.py format tab — beat count font size tooltip
msgid "Size of the beat-count number as a percentage of the chord font size (default: 60%)"
msgstr "Dimensione del numero di battiti come percentuale del carattere accordo (predefinito: 60%)"

#: PreferencesDialog.py format tab — beat count bold checkbox
msgid "Bold"
msgstr "Grassetto"

#: PreferencesDialog.py format tab — beat count bold tooltip
msgid "Draw the beat-count number in bold"
msgstr "Disegna il numero di battiti in grassetto"

#: PreferencesDialog.py format tab — beat count position label
msgid "Position"
msgstr "Posizione"

#: PreferencesDialog.py format tab — beat count align left
msgid "Left"
msgstr "Sinistra"

#: PreferencesDialog.py format tab — beat count align left tooltip
msgid "Show beat count to the left of the chord name"
msgstr "Mostra il numero di battiti a sinistra del nome accordo"

#: PreferencesDialog.py format tab — beat count align center
msgid "Center"
msgstr "Centro"

#: PreferencesDialog.py format tab — beat count align center tooltip
msgid "Show beat count centered above the chord name"
msgstr "Mostra il numero di battiti centrato sopra il nome accordo"

#: PreferencesDialog.py format tab — beat count align right
msgid "Right"
msgstr "Destra"

#: PreferencesDialog.py format tab — beat count align right tooltip
msgid "Show beat count to the right of the chord name"
msgstr "Mostra il numero di battiti a destra del nome accordo"

#: PreferencesDialog.py autoadjust tab — deco slider bar colour label
msgid "Level bar colour"
msgstr "Colore barra livello"

#: MyDecoSlider.py — etichetta sinistra barra livello
msgid "Easy"
msgstr "Facile"

#: MyDecoSlider.py — etichetta destra barra livello
msgid "Difficult"
msgstr "Difficile"

#: PreferencesDialog.py format tab — beat count display mode label
msgid "Display mode"
msgstr "Modalità visualizzazione"

#: PreferencesDialog.py format tab — beat count display mode: number
msgid "Number"
msgstr "Numero"

#: PreferencesDialog.py format tab — beat count display mode: number tooltip
msgid "Show beat count as a number above the chord"
msgstr "Mostra il conteggio dei battiti come numero sopra l'accordo"

#: PreferencesDialog.py format tab — beat count display mode: dots
msgid "Dots"
msgstr "Puntini"

#: PreferencesDialog.py format tab — beat count display mode: dots tooltip
msgid "Show beat count as dots between chords"
msgstr "Mostra il conteggio dei battiti come puntini tra gli accordi"

#: PreferencesDialog.py format tab — beat count display mode: both
msgid "Both"
msgstr "Entrambi"

#: PreferencesDialog.py format tab — beat count display mode: both tooltip
msgid "Show both number and dots"
msgstr "Mostra sia il numero che i puntini"

#: PreferencesDialog.py songpress tab — no chords blocks group title
msgid "No chords: blocks to hide"
msgstr "Nessun accordo: blocchi da nascondere"

#: PreferencesDialog.py songpress tab — no chords blocks header
msgid "When 'No chords' is selected, also hide:"
msgstr "Quando è selezionato 'Nessun accordo', nascondi anche:"

#: PreferencesDialog.py songpress tab — no chords blocks header tooltip
msgid ""
"Active only when 'Show chords' is set to 'No chords'.\n"
"Check each block type you want to hide from the preview and print."
msgstr ""
"Attivo solo quando 'Mostra accordi' è impostato su 'Nessun accordo'.\n"
"Seleziona i tipi di blocco da nascondere nell'anteprima e in stampa."

#: PreferencesDialog.py songpress tab — hide intro chord checkbox
msgid "Intro chords  {start_chord}\\{end_chord}"
msgstr "Accordi di intro  {start_chord}\\{end_chord}"

#: PreferencesDialog.py songpress tab — hide intro chord tooltip
msgid "Hide {start_chord}…{end_chord} blocks when no chords are shown."
msgstr "Nasconde i blocchi {start_chord}…{end_chord} quando gli accordi sono disabilitati."

#: PreferencesDialog.py songpress tab — hide bridge checkbox
msgid "Bridge  {start_bridge}\\{end_bridge}"
msgstr "Bridge  {start_bridge}\\{end_bridge}"

#: PreferencesDialog.py songpress tab — hide bridge tooltip
msgid "Hide {start_bridge}…{end_bridge} blocks when no chords are shown."
msgstr "Nasconde i blocchi {start_bridge}…{end_bridge} quando gli accordi sono disabilitati."

#: PreferencesDialog.py songpress tab — hide grid checkbox
msgid "Grid  {start_of_grid}\\{end_of_grid}"
msgstr "Griglia  {start_of_grid}\\{end_of_grid}"

#: PreferencesDialog.py songpress tab — hide grid tooltip
msgid "Hide {start_of_grid}…{end_of_grid} blocks when no chords are shown."
msgstr "Nasconde i blocchi {start_of_grid}…{end_of_grid} quando gli accordi sono disabilitati."

#: PreferencesDialog.py songpress tab — hide tempo checkbox
msgid "Tempo  {tempo_m}\\{tempo_s}\\{tempo_sp}\\{tempo_c}\\{tempo_cp}"
msgstr "Tempo  {tempo_m}\\{tempo_s}\\{tempo_sp}\\{tempo_c}\\{tempo_cp}"

#: PreferencesDialog.py songpress tab — hide tempo tooltip
msgid "Hide {tempo_m}, {tempo_s}, {tempo_sp}, {tempo_c}, {tempo_cp} directives when no chords are shown."
msgstr "Nasconde le direttive {tempo_m}, {tempo_s}, {tempo_sp}, {tempo_c}, {tempo_cp} quando gli accordi sono disabilitati."

#: PreferencesDialog.py songpress tab — hide time checkbox
msgid "Time signature  {time}"
msgstr "Indicazione di tempo  {time}"

#: PreferencesDialog.py songpress tab — hide time tooltip
msgid "Hide {time:...} directives when no chords are shown."
msgstr "Nasconde le direttive {time:...} quando gli accordi sono disabilitati."

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/Preferences.py:33
msgid "Above text"
msgstr "Sopra il testo"

#: /home/luca/Documenti/dev/Applicazioni/songpress/master/src/songpress/Preferences.py:34
msgid "Below text"
