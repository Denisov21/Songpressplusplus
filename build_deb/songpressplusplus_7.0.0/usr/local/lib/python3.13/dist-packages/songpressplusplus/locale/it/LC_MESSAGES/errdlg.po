#: errdlg.py
msgid "Unexpected error"
msgstr "Errore imprevisto"

#: errdlg.py
msgid ""
"An unexpected error occurred in {prog}.\n"
"Click \"Send error report\" to notify the developer,\n"
"or \"Close\" to continue (the program may be unstable)."
msgstr ""
"Si è verificato un errore imprevisto in {prog}.\n"
"Clicca su «Invia rapporto d'errore» per notificare lo sviluppatore,\n"
"oppure su «Chiudi» per continuare (il programma potrebbe essere instabile)."

#: errdlg.py
msgid "Error traceback:"
msgstr "Traceback dell'errore:"

#: errdlg.py
msgid "Force close"
msgstr "Forza chiusura"

#: errdlg.py
msgid "Force immediate application shutdown"
msgstr "Forza la chiusura immediata dell'applicazione"

#: errdlg.py
msgid "Copy"
msgstr "Copia"

#: errdlg.py
msgid "Copy error message to clipboard"
msgstr "Copia il messaggio di errore negli appunti"

#: errdlg.py
msgid "Send error report"
msgstr "Invia rapporto d'errore"

#: errdlg.py
msgid "Close"
msgstr "Chiudi"
